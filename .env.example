# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=codesync
POSTGRES_PASSWORD=change_me
POSTGRES_DB=codesync

# ── Spring Boot API ───────────────────────────────────────────────────────────
# Must be at least 32 characters; generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
# Used inside the container — points to the postgres service
DATABASE_URL=jdbc:postgresql://postgres:5432/codesync

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── AI service ────────────────────────────────────────────────────────────────
# host.docker.internal resolves to the Docker host; Ollama must be running there.
OLLAMA_URL=http://host.docker.internal:11434
AI_MODEL_HEAVY=qwen2.5-coder:7b
AI_MODEL_LIGHT=qwen2.5-coder:1.5b

# ── Execution sandbox ─────────────────────────────────────────────────────────
RUNNER_IMAGE=codesync-runner
RUNNER_TIMEOUT_SECONDS=10
RUNNER_MEMORY=256m
RUNNER_CPUS=0.5

# ── PHP Admin panel ───────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=change_me

# ── Frontend (build-time Vite vars) ──────────────────────────────────────────
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:1234
VITE_AI_URL=http://localhost:8001
